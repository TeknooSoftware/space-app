<!DOCTYPE html>
<html lang="{{ locale|default('en') }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ 'teknoo.space.error.dashboard.server.title'|trans }}</title>
  {% block stylesheet %}
    <link rel="stylesheet"
          href="{{ path(
            '_teknoo_common_minifier_css_version', {
              'setName': 'default',
              'version': assetsVersion
            }) }}">
  {% endblock %}{# stylesheet #}
</head>
<body class="bg-light">
  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-md-8 text-center">
        <div class="display-1 fw-bold text-muted mb-3">
          {{ 'teknoo.space.error.dashboard.server.upper'|trans }}
        </div>
        <h1 class="h3 mb-3">{{ 'teknoo.space.error.dashboard.server.title'|trans }}</h1>
        <p class="text-muted mb-4">{{ 'teknoo.space.error.dashboard.server.description'|trans }}</p>
        {% if error is defined and error is not null %}
          <div class="alert alert-secondary text-start mb-4">
            <small class="font-monospace">{{ error.message }}</small>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</body>
</html>
