{# templates/TeknooSpace/AccountCluster/edit.html.twig #}

{% extends '@TeknooSpace/dashboard.form.html.twig' %}

{% block title %}{{ 'teknoo.space.title.account.account_cluster.edit'|trans }} : {{ objectInstance }} - {% endblock %}

{%- block instanceMainTitle -%}
    <i class="uil uil-server"></i> {{ 'teknoo.space.title.account.account_cluster.edit'|trans }} : {{ objectInstance }}
{%- endblock -%}

{% block breadcrumFormTitle %}{{ 'teknoo.space.title.account.account_cluster.edit'|trans }}{% endblock %}
{%- block breadcrumbListLink path('space_account_clusters_list', {'accountId': account.id}) -%}
{% block breadcrumInstanceTitle %}{{ objectInstance }}{% endblock %}

{% block crudFormFields %}
    <div class="row">
        {{ form_row(formView.name) }}
        {{ form_row(formView.slug) }}
        {{ form_row(formView.type) }}
        {{ form_row(formView.masterAddress) }}
        {{ form_row(formView.storageProvisioner) }}
        {{ form_row(formView.dashboardAddress) }}
        {{ form_row(formView.caCertificate, {"largeRow": true}) }}
        {{ form_row(formView.token, {"largeRow": true}) }}
        {{ form_row(formView.registryUrl, {"largeRow": true}) }}
        {{ form_row(formView.supportRegistry) }}
        {{ form_row(formView.useHnc) }}
    </div>

{% endblock %}
